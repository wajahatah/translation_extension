{
  "manifest_version": 3,
  "name": "Quran Inline Translator",
  "version": "1.1",
  "description": "Translate selected Arabic text inline to Urdu.",
  "permissions": [
    "activeTab",
    "storage",
    "tabs",
    "webNavigation"
  ],
  "host_permissions": [
    "https://api.mymemory.translated.net/*",
    "http://localhost:5001/*",
    "http://localhost:5002/*",
    "<all_urls>"
  ],
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "css": ["style.css"],
      "all_frames": true
    }
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html"
  }
}